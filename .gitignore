# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data

.angular

.nx/polygraph
# Editor / AI tool local configs
.cursor/
.opencode/

# Capacitor native build outputs
/android/.gradle
/android/app/build
/android/build
/ios/App/App/public
/ios/DerivedData
*.p8
*.p12
*.mobileprovision
google-services.json
GoogleService-Info.plist

# Local environment secrets — never commit
.env
.env.local
.env.*.local

# Generated environment files — contain Firebase credentials, never commit
src/environments/environment.ts
src/environments/environment.prod.ts
src/environments/environment.staging.ts

# E2E auth state — contains browser storage with Firebase auth tokens
e2e/.auth/user.json
playwright-report/
