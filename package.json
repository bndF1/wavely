{
  "name": "@wavely/source",
  "version": "1.5.1",
  "license": "MIT",
  "scripts": {
    "generate-env": "node --env-file=.env scripts/generate-env.mjs",
    "start": "ENV_TARGET=dev node --env-file=.env scripts/generate-env.mjs && nx serve",
    "build": "nx build",
    "test": "nx test",
    "cap:build": "nx build && cp dist/wavely/browser/index.csr.html dist/wavely/browser/index.html",
    "cap:sync": "bun run cap:build && bunx cap sync",
    "cap:ios": "bun run cap:sync && bunx cap open ios",
    "cap:android": "bun run cap:sync && bunx cap open android",
    "cap:serve": "CAP_ENV=local bunx cap run ios --livereload --external"
  },
  "private": true,
